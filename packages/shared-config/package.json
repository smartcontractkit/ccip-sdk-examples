{
  "name": "@ccip-examples/shared-config",
  "version": "1.0.0",
  "description": "Shared network and token configuration for CCIP SDK examples",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./networks": {
      "types": "./dist/networks.d.ts",
      "import": "./dist/networks.js"
    },
    "./tokens": {
      "types": "./dist/tokens.d.ts",
      "import": "./dist/tokens.js"
    },
    "./wagmi": {
      "types": "./dist/wagmi.d.ts",
      "import": "./dist/wagmi.js"
    },
    "./queryClient": {
      "types": "./dist/queryClient.d.ts",
      "import": "./dist/queryClient.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@chainlink/ccip-sdk": "1.0.0",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@tanstack/react-query": "^5.62.0",
    "typescript": "^5.9.3",
    "viem": "^2.21.0",
    "wagmi": "^2.14.0"
  },
  "keywords": [
    "ccip",
    "config",
    "networks",
    "tokens"
  ],
  "peerDependencies": {
    "@chainlink/ccip-sdk": "1.0.0",
    "@rainbow-me/rainbowkit": ">=2.2.0",
    "@tanstack/react-query": ">=5.0.0",
    "viem": ">=2.21.0",
    "wagmi": ">=2.14.0"
  }
}
