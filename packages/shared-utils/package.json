{
  "name": "@ccip-examples/shared-utils",
  "version": "1.0.0",
  "description": "Shared utilities for CCIP SDK examples",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./ccipErrors": {
      "types": "./dist/ccipErrors.d.ts",
      "import": "./dist/ccipErrors.js"
    },
    "./validation": {
      "types": "./dist/validation.d.ts",
      "import": "./dist/validation.js"
    },
    "./viem": {
      "types": "./dist/viem.d.ts",
      "import": "./dist/viem.js"
    },
    "./wallet": {
      "types": "./dist/wallet.d.ts",
      "import": "./dist/wallet.js"
    },
    "./formatting": {
      "types": "./dist/formatting.d.ts",
      "import": "./dist/formatting.js"
    },
    "./clipboard": {
      "types": "./dist/clipboard.d.ts",
      "import": "./dist/clipboard.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aptos-labs/ts-sdk": "^5.2.1",
    "@coral-xyz/anchor": "^0.30.1",
    "@solana/web3.js": "^1.98.0",
    "bs58": "^6.0.0",
    "ethers": "^6.16.0",
    "viem": "^2.21.0",
    "@ccip-examples/shared-config": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@chainlink/ccip-sdk": "1.0.0"
  },
  "keywords": [
    "ccip",
    "utils",
    "errors",
    "validation"
  ],
  "peerDependencies": {
    "react": ">=18.0.0",
    "@chainlink/ccip-sdk": "1.0.0"
  }
}
