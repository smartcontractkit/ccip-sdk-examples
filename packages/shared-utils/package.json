{
  "name": "@ccip-examples/shared-utils",
  "version": "1.0.0",
  "description": "Shared utilities for CCIP SDK examples",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./validation": {
      "types": "./dist/validation.d.ts",
      "import": "./dist/validation.js"
    },
    "./viem": {
      "types": "./dist/viem.d.ts",
      "import": "./dist/viem.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@chainlink/ccip-sdk": "0.96.0",
    "@solana/web3.js": "^1.98.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "keywords": [
    "ccip",
    "utils",
    "errors",
    "validation"
  ]
}
