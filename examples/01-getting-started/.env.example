# ============================================================================
# Private keys for signing transactions (per chain family)
# ============================================================================
#
# Set the key(s) for the chain family you want to use.
# Both can coexist — the script picks the right one based on --source.

# --- EVM (Ethereum, Base, Avalanche, etc.) ---
# Hex private key (with or without 0x prefix)
# EVM_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# --- Solana (SVM) ---
# Either a path to a keypair JSON file (from solana-keygen):
#   SVM_PRIVATE_KEY=~/.config/solana/devnet.json
#
# Or a base58-encoded secret key:
#   SVM_PRIVATE_KEY=4wBqpZM9k...

# --- Aptos ---
# AIP-80 format (from `aptos init --network testnet`):
#   APTOS_PRIVATE_KEY=ed25519-priv-0x...
# Or raw hex:
#   APTOS_PRIVATE_KEY=0x...

# WARNING: Never commit your actual keys!

# ============================================================================
# Optional: Custom RPC URLs (defaults to public endpoints if not set)
# ============================================================================
# RPC_ETHEREUM_SEPOLIA=https://your-ethereum-sepolia-rpc
# RPC_BASE_SEPOLIA=https://your-base-sepolia-rpc
# RPC_AVALANCHE_FUJI=https://your-avalanche-fuji-rpc
# RPC_SOLANA_DEVNET=https://your-solana-devnet-rpc
# RPC_APTOS_TESTNET=https://your-aptos-testnet-rpc

# ============================================================================
# Getting started with Solana Devnet
# ============================================================================
#
# 1. Generate a keypair (if you don't have one):
#      solana-keygen new --outfile ~/.config/solana/devnet.json
#
# 2. Set SVM_PRIVATE_KEY to the keypair file path:
#      SVM_PRIVATE_KEY=~/.config/solana/devnet.json
#
# 3. Airdrop SOL for gas fees:
#      solana airdrop 3 --url devnet
#
# 4. Get CCIP-BnM test tokens from https://docs.chain.link/ccip/test-tokens
