{
  "name": "@ccip-examples/02-evm-simple-bridge",
  "version": "1.0.0",
  "description": "Simple EVM-to-EVM bridge using wagmi, viem, and RainbowKit",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@chainlink/ccip-sdk": "0.96.0",
    "@ccip-examples/shared-config": "workspace:*",
    "@ccip-examples/shared-utils": "workspace:*",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@tanstack/react-query": "^5.62.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "viem": "^2.21.0",
    "wagmi": "^2.14.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "typescript": "^5.9.3",
    "vite": "^6.0.5"
  },
  "keywords": [
    "ccip",
    "evm",
    "bridge",
    "wagmi",
    "viem",
    "rainbowkit"
  ]
}
